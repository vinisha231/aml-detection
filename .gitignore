# ─────────────────────────────────────────────
# .gitignore — files that should NOT go to GitHub
# ─────────────────────────────────────────────

# Python byte-compiled files (created automatically, not needed)
__pycache__/
*.pyc
*.pyo

# Virtual environment folder (your local Python packages)
venv/
.venv/
env/

# SQLite database files (generated by our pipeline, not tracked)
data/*.db
data/*.sqlite

# Node.js dependencies (too big, npm install regenerates them)
node_modules/
frontend/node_modules/

# Build outputs (generated files, not source)
dist/
build/
frontend/dist/

# Environment variable files (contain secrets — never commit these!)
.env
.env.local
.env.production

# MacOS metadata files
.DS_Store

# IDE-specific files
.vscode/
.idea/
*.swp

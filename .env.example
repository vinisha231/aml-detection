# .env.example
# ─────────────────────────────────────────────────────────────────────────────
# Environment variable template for the AML Detection System.
#
# Copy this file to .env and fill in the values before running the system.
# NEVER commit your actual .env file — it contains secrets.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   make run
# ─────────────────────────────────────────────────────────────────────────────


# ─── Application ──────────────────────────────────────────────────────────────

# Environment name — affects logging verbosity and error detail level
# Options: development, staging, production
APP_ENV=development

# Application host and port
APP_HOST=127.0.0.1
APP_PORT=8000


# ─── Database ─────────────────────────────────────────────────────────────────

# SQLite database file path (relative to project root)
# For production: use PostgreSQL with a connection string like:
#   DATABASE_URL=postgresql://user:password@host:5432/aml_db
DATABASE_URL=sqlite:///./aml.db


# ─── Logging ──────────────────────────────────────────────────────────────────

# Minimum log level. Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Use DEBUG for development (verbose), WARNING or above for production
LOG_LEVEL=INFO


# ─── Detection pipeline ───────────────────────────────────────────────────────

# Expected ratio of suspicious accounts in the dataset (for validation)
EXPECTED_SUSPICIOUS_RATIO=0.10

# Score threshold above which accounts are surfaced to analysts
ALERT_SCORE_THRESHOLD=50.0

# Number of workers for parallel rule evaluation (1 = sequential)
DETECTION_WORKERS=1


# ─── API ──────────────────────────────────────────────────────────────────────

# Allowed CORS origins (comma-separated)
# In development, the React dev server runs on localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limiting: max requests per token bucket period
RATE_LIMIT_MAX_TOKENS=60
RATE_LIMIT_REFILL_RATE=10


# ─── Data generation ──────────────────────────────────────────────────────────

# Number of accounts to generate
GENERATOR_ACCOUNT_COUNT=1000

# Number of transaction days to simulate
GENERATOR_SIM_DAYS=365

# Percentage of accounts to make suspicious (as a decimal)
GENERATOR_SUSPICIOUS_RATIO=0.10

# Random seed for reproducible generation (comment out for random)
# GENERATOR_SEED=42
